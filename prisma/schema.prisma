// Schéma de la base de données — plateforme de cartes de fidélité digitales.
// Architecture multi-tenant : un seul logiciel, plusieurs commerces isolés.
//
// On utilise PostgreSQL (compatible avec l'hébergement Vercel + Neon).
// En local comme en production, la connexion est lue depuis DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Un commerce client de la plateforme (un "tenant").
/// Ce n'est PAS forcément un restaurant : resto, coiffeur, boutique, etc.
model Business {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique // identifiant lisible dans les URLs, ex: "chez-mario"
  category  String?  // type de commerce : "Restaurant", "Coiffeur", "Boutique"…
  logoUrl   String?
  color     String   @default("#6e1023") // couleur de marque (bordeaux par défaut)
  // Connexion du commerçant à son espace (scanner, dashboard…).
  // L'identifiant de connexion est le `slug`, le mot de passe est haché ici.
  passwordHash String?
  // Statut de l'abonnement vendu au commerce
  plan      String   @default("trial") // trial | starter | pro | multi
  createdAt DateTime @default(now())

  programs  LoyaltyProgram[]
  customers Customer[]
  campaigns Campaign[]
}

/// Le programme de fidélité d'un commerce : "X tampons = 1 récompense".
model LoyaltyProgram {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name         String   // ex: "Carte café"
  // Objectif principal de la carte (max 15 tampons côté interface).
  stampsGoal   Int      @default(10) // nombre de tampons pour gagner
  rewardLabel  String   @default("1 produit offert") // récompense principale (objectif atteint)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  cards        StampCard[]
  rewards      Reward[]
}

/// Une récompense proposée par le commerçant dans son programme.
/// Le client la débloque à partir d'un certain nombre de tampons.
/// Peut être un cadeau ("gift") ou un coupon de réduction ("coupon").
model Reward {
  id            String   @id @default(cuid())
  programId     String
  program       LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  title         String   // ex: "1 café offert"
  description   String?  // détail optionnel
  type          String   @default("gift") // "gift" (cadeau) | "coupon" (réduction)
  pointsRequired Int     @default(10) // tampons nécessaires pour débloquer
  imageUrl      String?  // photo optionnelle (data URL ou URL externe)
  couponCode    String?  // code de réduction (pour type "coupon")
  active        Boolean  @default(true)
  position      Int      @default(0) // ordre d'affichage
  createdAt     DateTime @default(now())
}

/// Une campagne de notification push créée par le commerçant.
/// trigger = "now" (envoi immédiat) | "scheduled" (date programmée)
///           | "birthday" (automatique le jour d'anniversaire du client 🎂)
model Campaign {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  title       String
  message     String
  trigger     String   @default("now") // now | scheduled | birthday
  scheduledAt DateTime?               // date d'envoi si trigger = "scheduled"
  status      String   @default("draft") // draft | scheduled | active | sent
  sentAt      DateTime?
  createdAt   DateTime @default(now())
}

/// Un client final d'un commerce.
/// Renseigné lors de l'inscription (1er scan) : prénom, nom, anniversaire.
model Customer {
  id           String    @id @default(cuid())
  businessId   String
  business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  firstName    String?
  lastName     String?
  birthdate    DateTime? // date d'anniversaire (pour les promos d'anniversaire)
  phone        String?
  email        String?
  createdAt    DateTime  @default(now())

  cards        StampCard[]
}

/// La carte de fidélité concrète d'un client (ce qui finira dans le Wallet).
model StampCard {
  id          String   @id @default(cuid())
  programId   String
  program     LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Jeton public unique mis dans le QR code et l'URL de la carte.
  // On ne met jamais l'id interne dans une URL publique.
  publicToken String   @unique @default(cuid())

  stampsCount Int      @default(0) // tampons sur le cycle en cours
  createdAt   DateTime @default(now())

  stamps      Stamp[]
  redemptions RewardRedemption[]
}

/// Un tampon ajouté (chaque passage du client).
model Stamp {
  id          String   @id @default(cuid())
  cardId      String
  card        StampCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

/// Une récompense récupérée par le client (carte complète -> remise à zéro).
model RewardRedemption {
  id          String   @id @default(cuid())
  cardId      String
  card        StampCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label       String
  createdAt   DateTime @default(now())
}
